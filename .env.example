# Resend API key — get from resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Your email — you get notified when tasks are completed or overdue
NEXT_PUBLIC_MANAGER_EMAIL=your@email.com

# Your app's live URL on Vercel (fill this in after deploying)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Secret to protect the cron job endpoint — make up any random string
CRON_SECRET=make_up_any_random_string_here
